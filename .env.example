# QuantForge environment template — copy to `.env` and edit.

# === API auth ===============================================================
# Comma-separated SHA-256 hex digests of raw keys. Generate with:
#   echo -n 'my-real-key' | sha256sum | awk '{print $1}'
QUANTFORGE_API_KEYS=

# Allow requests without X-API-Key (only for dev behind another gateway)
QUANTFORGE_ALLOW_UNAUTH=false

# Extra CORS origins (comma-separated)
QUANTFORGE_CORS_ORIGINS=

# === Logging ================================================================
QUANTFORGE_LOG_LEVEL=INFO

# === Server =================================================================
QUANTFORGE_API_HOST=0.0.0.0
QUANTFORGE_API_PORT=8000
QUANTFORGE_MAX_BODY_KB=256
QUANTFORGE_RATE_LIMIT_PER_MINUTE=120
QUANTFORGE_RATE_LIMIT_PER_HOUR=2000

# === JWT (optional) =========================================================
# Leave empty to disable JWT auth (X-API-Key still works).
QUANTFORGE_JWT_SECRET=
QUANTFORGE_JWT_ISSUER=quantforge
QUANTFORGE_JWT_AUDIENCE=quantforge-api
QUANTFORGE_JWT_ALG=HS256

# === Cache ==================================================================
# Empty → in-memory fallback. Set to redis://redis:6379/0 in docker-compose.
REDIS_URL=

# === OpenTelemetry (optional) ===============================================
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318/v1/traces
OTEL_SERVICE_NAME=quantforge-api

# === Job queue ==============================================================
QUANTFORGE_JOB_MAX_WORKERS=4
QUANTFORGE_JOB_MAX_QUEUED=100
QUANTFORGE_JOB_PER_OWNER_INFLIGHT_CAP=10

# === Data cache ============================================================
QUANTFORGE_CACHE_DIR=data/cache
