{
  "annotations": {
    "list": [
      { "builtIn": 1, "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)", "name": "Annotations & Alerts", "type": "dashboard" }
    ]
  },
  "description": "QuantForge API — request rate, latency, error rate, in-flight, cache hit ratio.",
  "editable": true, "fiscalYearStartMonth": 0, "graphTooltip": 1, "id": null,
  "liveNow": true, "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark", "tags": ["quantforge", "api"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "QuantForge API",
  "uid": "quantforge-api",
  "version": 1,
  "panels": [
    {
      "type": "stat", "title": "In-flight requests",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [ { "expr": "qf_in_flight_requests", "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" },
        "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 20 }, { "color": "red", "value": 50 } ] } } }
    },
    {
      "type": "stat", "title": "Requests / sec",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [ { "expr": "sum(rate(qf_requests_total[1m]))", "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] } } }
    },
    {
      "type": "stat", "title": "5xx error rate",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [ { "expr": "sum(rate(qf_requests_total{status=~\"5..\"}[5m])) / sum(rate(qf_requests_total[5m]))", "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "percentunit",
        "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 0.01 }, { "color": "red", "value": 0.05 } ] } } }
    },
    {
      "type": "stat", "title": "p99 latency",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [ { "expr": "histogram_quantile(0.99, sum(rate(qf_request_latency_seconds_bucket[5m])) by (le))", "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "s",
        "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 0.5 }, { "color": "red", "value": 2 } ] } } }
    },
    {
      "type": "timeseries", "title": "Request rate by path",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [ { "expr": "sum by (path) (rate(qf_requests_total[1m]))", "refId": "A", "legendFormat": "{{path}}" } ]
    },
    {
      "type": "timeseries", "title": "Latency quantiles",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(qf_request_latency_seconds_bucket[5m])) by (le))", "refId": "A", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(qf_request_latency_seconds_bucket[5m])) by (le))", "refId": "B", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(qf_request_latency_seconds_bucket[5m])) by (le))", "refId": "C", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "timeseries", "title": "Status codes",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 7 },
      "targets": [ { "expr": "sum by (status) (rate(qf_requests_total[1m]))", "refId": "A", "legendFormat": "{{status}}" } ]
    },
    {
      "type": "timeseries", "title": "Cache hit ratio",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 7 },
      "targets": [
        { "expr": "sum(rate(qf_cache_hits_total[5m])) / (sum(rate(qf_cache_hits_total[5m])) + sum(rate(qf_cache_misses_total[5m])))", "refId": "A", "legendFormat": "hit ratio" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    }
  ]
}
