# QuantForge — production environment template
# ==============================================
# DO NOT commit a filled-in copy of this file. In production these values
# belong in the deployment platform's secret store:
#   - Render: Dashboard → Service → Environment
#   - Vercel: Project → Settings → Environment Variables
#   - Kubernetes: a Secret manifest applied out-of-band
#
# Every variable marked REQUIRED must be set. Optional ones have safe
# defaults baked into quantforge/config.py.
#
# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------

# REQUIRED. Comma-separated SHA-256 hex digests of the raw API keys you
# hand to clients. Generate one per client:
#   raw=$(openssl rand -hex 32)
#   hash=$(printf '%s' "$raw" | sha256sum | awk '{print $1}')
#   echo "raw (give to client): $raw"
#   echo "hash (put in this var): $hash"
# Rotate by adding the new hash, waiting for clients to migrate, then
# removing the old hash.
QUANTFORGE_API_KEYS=<hash1,hash2,...>

# REQUIRED in prod. Never set to true outside dev — any request without
# X-API-Key will be accepted if this is true.
QUANTFORGE_ALLOW_UNAUTH=false

# REQUIRED. Comma-separated list of browser origins allowed to call this
# API via CORS. Omit scheme-only entries (use the full origin). Example:
#   https://quantforge.vercel.app,https://quantforge-staging.vercel.app
QUANTFORGE_CORS_ORIGINS=https://<your-frontend>.vercel.app

# ---------------------------------------------------------------------------
# JWT (second auth method, used when X-API-Key is inconvenient — e.g. SSO)
# ---------------------------------------------------------------------------

# REQUIRED if you enable JWT auth on any route. Must be >= 32 random bytes
# for HS256. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Rotate quarterly.
QUANTFORGE_JWT_SECRET=<64+ url-safe random chars>
QUANTFORGE_JWT_ISSUER=quantforge
QUANTFORGE_JWT_AUDIENCE=quantforge-api
QUANTFORGE_JWT_ALG=HS256

# ---------------------------------------------------------------------------
# Rate limiting (sane prod defaults — tune per your load)
# ---------------------------------------------------------------------------
QUANTFORGE_RATE_LIMIT_PER_MINUTE=120
QUANTFORGE_RATE_LIMIT_PER_HOUR=2000
QUANTFORGE_MAX_BODY_KB=256

# ---------------------------------------------------------------------------
# Persistence
# ---------------------------------------------------------------------------

# When deployed to Render, these point at a mounted persistent disk so the
# audit log + cache survive redeploys. Match the disk's mountPath.
QUANTFORGE_CACHE_DIR=/app/data/cache
QUANTFORGE_AUDIT_DB=/app/data/audit.db

# Optional managed Redis. If unset the API falls back to an in-memory cache
# (fine for single-instance deploys; mandatory for multi-instance).
# REDIS_URL=rediss://<user>:<pass>@<host>:<port>/0

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
QUANTFORGE_LOG_LEVEL=INFO

# Optional OpenTelemetry export. Point at an OTLP/HTTP collector.
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.example.com/v1/traces
OTEL_SERVICE_NAME=quantforge-api

# ---------------------------------------------------------------------------
# Job queue
# ---------------------------------------------------------------------------
QUANTFORGE_JOB_MAX_WORKERS=4
QUANTFORGE_JOB_MAX_QUEUED=100
QUANTFORGE_JOB_PER_OWNER_INFLIGHT_CAP=10

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
# Render injects $PORT automatically — don't hardcode.
QUANTFORGE_API_HOST=0.0.0.0
